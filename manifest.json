{
  "manifest_version": 3,
  "name": "Course Video Queue Recorder",
  "version": "1.0.1",
  "description": "Record course videos from a dynamic queue with auto-play and silence detection",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "offscreen",
    "tabCapture",
    "storage",
    "identity"
  ],
  "oauth2": {
    "client_id": "1032034802604-9tejdjc0b17e65tthens4kf13voq8rmu.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
